POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

DB_URL=jdbc:postgresql://postgres:5432/gaime_bridge
DB_USERNAME=gaime_bridge
DB_PASSWORD=gaime_bridge

API_USERNAME=dev
API_PASSWORD=dev123
APP_DEMO_ENABLED=true

APP_PORT=8080

# Temporary live Asan/e-Taxes flow.
# This is a first live-integration scaffold, not the final user-facing login UX.
TAX_PORTAL_BROWSER_ENABLED=false
TAX_PORTAL_HEADLESS=false
TAX_PORTAL_BASE_URL=https://new.e-taxes.gov.az

# Asan login inputs:
# - TAX_PORTAL_USERNAME = phone without +994
# - TAX_PORTAL_PASSWORD = Asan userId
TAX_PORTAL_LOGIN_URL=/eportal/login/asan
TAX_PORTAL_USERNAME=
TAX_PORTAL_PASSWORD=
TAX_PORTAL_USERNAME_SELECTOR=#phone
TAX_PORTAL_PASSWORD_SELECTOR=#userId
TAX_PORTAL_SUBMIT_SELECTOR=#loginPageSigninButton
TAX_PORTAL_SUCCESS_SELECTOR=

# Verification and taxpayer selection.
TAX_PORTAL_VERIFICATION_URL=/eportal/verification/asan
TAX_PORTAL_VERIFICATION_PENDING_SELECTOR=
TAX_PORTAL_VERIFICATION_START_PATH=/api/po/auth/public/v1/asanImza/start
TAX_PORTAL_VERIFICATION_STATUS_PATH=/api/po/auth/public/v1/asanImza/status
TAX_PORTAL_CERTIFICATES_PATH=/api/po/auth/public/v1/asanImza/certificates
TAX_PORTAL_CHOOSE_TAXPAYER_PATH=/api/po/auth/public/v1/asanImza/chooseTaxpayer
TAX_PORTAL_OWNER_TYPE=legal
TAX_PORTAL_LEGAL_TIN=
TAX_PORTAL_POLL_INTERVAL=2s
TAX_PORTAL_VERIFICATION_TIMEOUT=3m
TAX_PORTAL_HOME_URL=/eportal/
TAX_PORTAL_HOME_SUCCESS_SELECTOR=

# Invoice JSON API layer.
TAX_PORTAL_SOURCE_SYSTEM=avis
TAX_PORTAL_INBOX_PATH=/api/po/invoice/public/v2/invoice/find.inbox
TAX_PORTAL_OUTBOX_PATH=/api/po/invoice/public/v2/invoice/find.outbox
TAX_PORTAL_DRAFT_PATH=/api/po/invoice/public/v2/invoice/find.draft
TAX_PORTAL_DETAIL_PATH_TEMPLATE=/api/po/invoice/public/v2/invoice/{id}?sourceSystem={sourceSystem}
TAX_PORTAL_VERSIONS_PATH_TEMPLATE=/api/po/invoice/public/v2/invoice/{id}/versions?sourceSystem={sourceSystem}
TAX_PORTAL_HISTORY_PATH_TEMPLATE=/api/po/invoice/public/v2/invoice/{id}/history?sourceSystem={sourceSystem}
TAX_PORTAL_TREE_PATH_TEMPLATE=/api/po/invoice/public/v2/invoice/{id}/tree?sourceSystem={sourceSystem}
TAX_PORTAL_PARENT_HISTORIES_PATH_TEMPLATE=/api/po/invoice/public/v2/invoice/{serialNumber}/parent-histories?sourceSystem={sourceSystem}
TAX_PORTAL_INBOX_PAYLOAD_TEMPLATE={"page":{{page}},"year":{{year}}}
TAX_PORTAL_OUTBOX_PAYLOAD_TEMPLATE={"page":{{page}},"year":{{year}}}
TAX_PORTAL_DRAFT_PAYLOAD_TEMPLATE={"page":{{page}},"year":{{year}}}
